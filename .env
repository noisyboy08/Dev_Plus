# Dev-Pulse Environment Variables

# ==========================================
# Database Configuration
# ==========================================
# Connection string for your PostgreSQL database.
# Example: postgresql://username:password@localhost:5432/devpulse
DATABASE_URL=postgresql://dummy:dummy@localhost:5432/dummy

# ==========================================
# Authentication (GitHub OAuth)
# ==========================================
# Create a GitHub OAuth app at https://github.com/settings/applications/new
# Authorization callback URL should be: http://localhost:8080/api/auth/github/callback
GITHUB_CLIENT_ID=Ov23liC47sAZ0q35PhRu
GITHUB_CLIENT_SECRET=6b54c727df7ae101338d7617aeb405d77b358070

# The domain where your backend is running locally
CLIENT_URL=http://localhost:5173
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/github/callback

# Session Secret (used for securing user sessions)
SESSION_SECRET=devpulse-super-secret-key-change-me

# ==========================================
# AI Integrations (Anthropic/Claude)
# ==========================================
AI_INTEGRATIONS_ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

# ==========================================
# Application Environment
# ==========================================
NODE_ENV=development
PORT=8080
